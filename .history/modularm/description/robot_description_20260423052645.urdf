<?xml version="1.0"?>
<robot name="visual">

  <material name="blue">
    <color rgba="0 0 0.8 1" />
  </material>
  <material name="black">
    <color rgba="0 0 0 1" />
  </material>
  <material name="white">
    <color rgba="1 1 1 1" />
  </material>

  <link name="base_link">
    <visual>
      <origin rpy="-1.57075 0 0" xyz="0 0 0" />

      <geometry>
        <mesh filename="package://modularm/description/meshes/base_link.stl" scale="0.1 0.1 0.1" />
      </geometry>
    </visual>
    <collision>
      <origin rpy="-1.57075 0 0" xyz="0 0 0" />
      <geometry>
        <mesh filename="package://modularm/description/meshes/base_link.stl" scale="0.1 0.1 0.1" />
      </geometry>
    </collision>

  </link>

  <joint name="joint_shaft" type="fixed">
    <parent link="base_link" />
    <child link="shaft" />
    <origin xyz="0 0 0" rpy="0 0 0" />
    <axis xyz="0 0 1" />
    <limit lower="-1.0" upper="1.0" effort="100" velocity="100" />
  </joint>
  <link name="shaft">
    <visual>
      <origin rpy="0.0 1.57075 0" xyz="0 -3.8 -0.1" />

      <geometry>
        <mesh filename="package://modularm/description/meshes/shaft.stl" scale="0.1 0.1 0.1" />
      </geometry>
    </visual>
    <collision>
      <origin rpy="0.0 1.57075 0" xyz="0 -3.8 -0.1" />
      <geometry>
        <mesh filename="package://modularm/description/meshes/shaft.stl" scale="0.1 0.1 0.1" />
      </geometry>
    </collision>

  </link>
  <joint name="shaft_joint" type="revolute">
    <parent link="shaft" />
    <child link="clamp" />
    <origin xyz="0 0 0" rpy="0 0 0" />
    <axis xyz="0 0 1" />
    <limit lower="-1.0" upper="1.0" effort="100" velocity="100" />
  </joint>
  <link name="clamp">
    <visual>
      <origin rpy="1.57075 0 0" xyz="0 -7.6 0" />

      <geometry>
        <mesh filename="package://modularm/description/meshes/clamp.stl" scale="0.1 0.1 0.1" />
      </geometry>
    </visual>
    <collision>
      <origin rpy="1.57075 0 0" xyz="0 -7.6 0" />
      <geometry>
        <mesh filename="package://modularm/description/meshes/clamp.stl" scale="0.1 0.1 0.1" />
      </geometry>
    </collision>
  </link>
  <joint name="joint_link" type="fixed">
    <parent link="clamp" />
    <child link="link" />
    <origin xyz="0 0 0" rpy="0 0 0" />
    <axis xyz="1 0 0" />
    <limit lower="-1.0" upper="1.0" effort="100" velocity="100" />
  </joint>
  <link name="link">
    <visual>
      <origin rpy="0 0 -1.57075" xyz="0 -7.6 0" />

      <geometry>
        <mesh filename="package://modularm/description/meshes/link.stl" scale="0.1 0.1 0.1" />
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 -1.57075" xyz="0 -7.6 0" />
      <geometry>
        <mesh filename="package://modularm/description/meshes/link.stl" scale="0.1 0.1 0.1" />
      </geometry>
    </collision>
  </link>
  <joint name="joint2" type="fixed">
    <parent link="link" />
    <child link="clamp2" />
    <origin xyz="0 0 0" rpy="0 0 0" />
    <axis xyz="1 0 0" />
    <limit lower="-1.0" upper="1.0" effort="100" velocity="100" />
  </joint>
  <link name="clamp2">
    <visual>
      <origin rpy="1.57075 0 0" xyz="0 -33.1 0" />

      <geometry>
        <mesh filename="package://modularm/description/meshes/clamp.stl" scale="0.1 0.1 0.1" />
      </geometry>
    </visual>
    <collision>
      <origin rpy="1.57075 0 0" xyz="0 -33.1 0" />
      <geometry>
        <mesh filename="package://modularm/description/meshes/clamp.stl" scale="0.1 0.1 0.1" />
      </geometry>
    </collision>
    </link> 
<joint name="joint_shaft2" type="fixed">
    <parent link="clamp2" />
    <child link="shaft2" />
    <origin xyz="0 0 0" rpy="0 0 0" />
    <axis xyz="0 0 1" />
    <limit lower="-1.0" upper="1.0" effort="100" velocity="100" />
  </joint>
  <link name="shaft2">
    <visual>
      <origin rpy="0.0 1.57075 0" xyz="0 -37 0.1" />

      <geometry>
        <mesh filename="package://modularm/description/meshes/shaft.stl" scale="0.1 0.1 0.1" />
      </geometry>
    </visual>
    <collision>
      <origin rpy="0.0 1.57075 0" xyz="0 -37 0.1" />
      <geometry>
        <mesh filename="package://modularm/description/meshes/shaft.stl" scale="0.1 0.1 0.1" />
      </geometry>
    </collision>

  </link>
</robot>