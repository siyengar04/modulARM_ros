<?xml version="1.0"?>
<robot name="visual">

<material name="blue">
    <color rgba="0 0 0.8 1"/>
  </material>
  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>
  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>

  <link name="base_link">
    <visual>
            <origin rpy="-1.57075 0 0" xyz="0 0 0"/>

      <geometry>
          <mesh filename="package://modularm/description/meshes/base_link.stl" scale="0.1 0.1 0.1" />
      </geometry>
    </visual>
    <collision>
            <origin rpy="-1.57075 0 0" xyz="0 0 0"/>
      <geometry>
          <mesh filename="package://modularm/description/meshes/base_link.stl" scale="0.1 0.1 0.1"/>
      </geometry>
    </collision>

  </link>

<joint name="base_shaft" type="fixed">
  <parent link="base_link" />
  <child link="shaft" />
  <origin xyz="0 0 0" rpy="0 0 0" />
  <axis xyz="0 0 1" />
  <limit lower="-1.0" upper="1.0" effort="100" velocity="100" />
</joint>
<link name="shaft">
    <visual>
            <origin rpy="0.0 0 0" xyz="0 -4 0"/>

      <geometry>
          <mesh filename="package://modularm/description/meshes/shaft.stl" scale="0.1 0.1 0.1"/>
      </geometry>
    </visual>
    <collision>
            <origin rpy="-1.57075 0 0" xyz="0 0 0"/>
      <geometry>
          <mesh filename="package://modularm/description/meshes/shaft.stl" scale="0.1 0.1 0.1"/>
      </geometry>
    </collision>

  </link>

</robot>